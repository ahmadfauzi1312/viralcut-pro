import re
import requests

YOUTUBE_API_BASE = "https://www.googleapis.com/youtube/v3"

def extract_video_id(url: str) -> str:
    """Extract YouTube video ID from various URL formats."""
    patterns = [
        r'(?:v=|/v/|youtu\.be/|/embed/|/shorts/)([a-zA-Z0-9_-]{11})',
        r'^([a-zA-Z0-9_-]{11})$',
    ]
    for pattern in patterns:
        match = re.search(pattern, url.strip())
        if match:
            return match.group(1)
    return ""


def get_video_details(api_key: str, video_ids: list) -> list:
    """Fetch full video details from YouTube API."""
    if not video_ids:
        return []
    params = {
        "part": "snippet,statistics,contentDetails",
        "id": ",".join(video_ids),
        "key": api_key,
    }
    resp = requests.get(f"{YOUTUBE_API_BASE}/videos", params=params, timeout=12)
    resp.raise_for_status()
    return resp.json().get("items", [])


def parse_duration_seconds(iso_duration: str) -> int:
    """Convert ISO 8601 duration to seconds."""
    match = re.match(
        r'PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?',
        iso_duration or ""
    )
    if not match:
        return 0
    h = int(match.group(1) or 0)
    m = int(match.group(2) or 0)
    s = int(match.group(3) or 0)
    return h * 3600 + m * 60 + s


def analyze_viral_potential(views: int, likes: int, comments: int,
                             duration_sec: int, published: str) -> dict:
    """
    Score each video across multiple viral dimensions.
    Returns scores and a list of recommended clip segments.
    """
    from datetime import date, datetime

    # Engagement rate
    engagement = (likes + comments) / max(views, 1) * 100

    # View velocity (views per day since published)
    try:
        pub_date = datetime.strptime(published[:10], "%Y-%m-%d").date()
        days_old = max((date.today() - pub_date).days, 1)
    except Exception:
        days_old = 30
    view_velocity = views / days_old

    # Score components (0-100 each)
    # 1. View score
    if views >= 10_000_000:   view_score = 100
    elif views >= 5_000_000:  view_score = 85
    elif views >= 2_000_000:  view_score = 70
    elif views >= 1_000_000:  view_score = 60
    elif views >= 500_000:    view_score = 50
    elif views >= 100_000:    view_score = 35
    elif views >= 50_000:     view_score = 25
    else:                     view_score = 10

    # 2. Engagement score
    if engagement >= 10:    eng_score = 100
    elif engagement >= 6:   eng_score = 85
    elif engagement >= 4:   eng_score = 70
    elif engagement >= 2:   eng_score = 55
    elif engagement >= 1:   eng_score = 40
    else:                   eng_score = 20

    # 3. Velocity score
    if view_velocity >= 500_000:   vel_score = 100
    elif view_velocity >= 100_000: vel_score = 85
    elif view_velocity >= 50_000:  vel_score = 70
    elif view_velocity >= 10_000:  vel_score = 55
    elif view_velocity >= 1_000:   vel_score = 40
    else:                          vel_score = 20

    # 4. Duration score (shorter = more clippable)
    if duration_sec <= 180:        dur_score = 90
    elif duration_sec <= 600:      dur_score = 75
    elif duration_sec <= 1200:     dur_score = 60
    elif duration_sec <= 3600:     dur_score = 45
    else:                          dur_score = 30

    # Weighted total
    total = int(view_score * 0.35 + eng_score * 0.30 + vel_score * 0.25 + dur_score * 0.10)

    # Clip segment recommendations based on video duration
    segments = generate_clip_segments(duration_sec, total)

    return {
        "viral_score": min(100, total),
        "view_score": view_score,
        "engagement_score": eng_score,
        "velocity_score": vel_score,
        "engagement_rate": round(engagement, 2),
        "view_velocity": int(view_velocity),
        "days_old": days_old,
        "segments": segments,
    }


def generate_clip_segments(duration_sec: int, viral_score: int) -> list:
    """
    Generate recommended clip segments with timestamps.
    Strategy: hook (opening), peak moments, closing CTA.
    """
    segments = []

    if duration_sec <= 0:
        return segments

    # Determine clip duration based on viral score
    if viral_score >= 85:
        clip_dur = 30
    elif viral_score >= 70:
        clip_dur = 60
    elif viral_score >= 55:
        clip_dur = 90
    else:
        clip_dur = 120

    def fmt(sec):
        m, s = divmod(int(sec), 60)
        h, m = divmod(m, 60)
        if h:
            return f"{h}:{m:02d}:{s:02d}"
        return f"{m}:{s:02d}"

    # Segment 1: Hook — first 15-30 seconds (always most important)
    hook_end = min(clip_dur, duration_sec)
    segments.append({
        "id": "hook",
        "label": "🎯 Hook / Opening",
        "description": "Bagian pembuka yang menarik perhatian — paling penting untuk short clip",
        "start_sec": 0,
        "end_sec": hook_end,
        "start_fmt": "0:00",
        "end_fmt": fmt(hook_end),
        "clip_duration": clip_dur,
        "potential": "Sangat Tinggi",
        "potential_color": "#10b981",
        "reason": "Detik pertama menentukan apakah viewer lanjut nonton atau scroll",
        "recommended_for": ["TikTok", "Reels", "Shorts"],
    })

    # Segment 2: Peak moment — 20-35% into video
    if duration_sec > clip_dur * 2:
        peak_start = int(duration_sec * 0.20)
        peak_end = min(peak_start + clip_dur, duration_sec)
        segments.append({
            "id": "peak",
            "label": "🔥 Momen Puncak",
            "description": "Bagian paling menarik / klimaks konten",
            "start_sec": peak_start,
            "end_sec": peak_end,
            "start_fmt": fmt(peak_start),
            "end_fmt": fmt(peak_end),
            "clip_duration": clip_dur,
            "potential": "Tinggi",
            "potential_color": "#f59e0b",
            "reason": "Biasanya bagian reveal, reaction, atau poin utama konten",
            "recommended_for": ["TikTok", "Reels"],
        })

    # Segment 3: Mid insight — 45-60% into video
    if duration_sec > clip_dur * 3:
        mid_start = int(duration_sec * 0.45)
        mid_end = min(mid_start + clip_dur, duration_sec)
        segments.append({
            "id": "insight",
            "label": "💡 Key Insight",
            "description": "Poin informasi atau tips terpenting dari video",
            "start_sec": mid_start,
            "end_sec": mid_end,
            "start_fmt": fmt(mid_start),
            "end_fmt": fmt(mid_end),
            "clip_duration": clip_dur,
            "potential": "Tinggi",
            "potential_color": "#8b5cf6",
            "reason": "Konten informatif / edukatif sangat cocok untuk format pendek",
            "recommended_for": ["Shorts", "Reels"],
        })

    # Segment 4: CTA / Closing — last portion
    if duration_sec > clip_dur * 2:
        cta_start = max(0, duration_sec - clip_dur - 10)
        cta_end = max(cta_start + clip_dur, duration_sec)
        cta_end = min(cta_end, duration_sec)
        segments.append({
            "id": "cta",
            "label": "📢 Call to Action",
            "description": "Bagian penutup dengan ajakan subscribe / follow / beli",
            "start_sec": int(cta_start),
            "end_sec": int(cta_end),
            "start_fmt": fmt(cta_start),
            "end_fmt": fmt(cta_end),
            "clip_duration": clip_dur,
            "potential": "Sedang",
            "potential_color": "#3b82f6",
            "reason": "Bagus untuk konten brand awareness dan promosi",
            "recommended_for": ["YouTube Shorts"],
        })

    return segments


