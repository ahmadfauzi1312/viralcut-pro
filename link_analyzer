def analyze_links(api_key: str, urls: list) -> list:
    """
    Main function: analyze multiple YouTube links,
    return sorted segments with viral potential.
    """
    # Extract video IDs
    video_ids = []
    url_map = {}
    for url in urls:
        vid_id = extract_video_id(url.strip())
        if vid_id and vid_id not in url_map:
            video_ids.append(vid_id)
            url_map[vid_id] = url.strip()

    if not video_ids:
        return []

    # Fetch details from YouTube API
    items = get_video_details(api_key, video_ids)

    results = []
    for item in items:
        snippet = item.get("snippet", {})
        stats = item.get("statistics", {})
        content = item.get("contentDetails", {})

        video_id = item.get("id", "")
        title = snippet.get("title", "")
        channel = snippet.get("channelTitle", "")
        published = snippet.get("publishedAt", "")[:10]
        description = snippet.get("description", "")[:500]

        views = int(stats.get("viewCount", 0))
        likes = int(stats.get("likeCount", 0))
        comments = int(stats.get("commentCount", 0))

        duration_iso = content.get("duration", "PT0S")
        duration_sec = parse_duration_seconds(duration_iso)

        thumbs = snippet.get("thumbnails", {})
        thumbnail = (thumbs.get("maxres") or thumbs.get("high") or thumbs.get("medium") or {}).get("url", "")

        from youtube import detect_genre, format_count
        cat_id = snippet.get("categoryId", "")
        genre = detect_genre(cat_id, title)

        analysis = analyze_viral_potential(views, likes, comments, duration_sec, published)

        # Generate captions for each segment
        for seg in analysis["segments"]:
            seg["captions"] = generate_clip_captions(
                title, genre, seg["label"], channel, analysis["viral_score"]
            )

        from youtube import format_count
        results.append({
            "video_id": video_id,
            "url": url_map.get(video_id, f"https://youtu.be/{video_id}"),
            "title": title,
            "channel": channel,
            "thumbnail": thumbnail,
            "published": published,
            "description": description,
            "views": format_count(views),
            "views_raw": views,
            "likes": format_count(likes),
            "likes_raw": likes,
            "comments": format_count(comments),
            "genre": genre,
            "duration_sec": duration_sec,
            "duration_fmt": f"{duration_sec // 60}:{duration_sec % 60:02d}",
            "viral_score": analysis["viral_score"],
            "view_score": analysis["view_score"],
            "engagement_score": analysis["engagement_score"],
            "velocity_score": analysis["velocity_score"],
            "engagement_rate": analysis["engagement_rate"],
            "view_velocity": analysis["view_velocity"],
            "days_old": analysis["days_old"],
            "segments": analysis["segments"],
        })

    # Sort by viral score descending
    results.sort(key=lambda x: x["viral_score"], reverse=True)
    return results
